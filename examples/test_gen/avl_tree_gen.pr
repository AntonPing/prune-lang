datatype Tree[a] where
| Empty
| Node(Tree[a], a, Tree[a])
end

datatype Option[a] where
| None
| Some(a)
end

function is_balanced[a](tree: Tree[a]) -> Bool
begin
    match is_balanced_help(tree) with
    | None => false
    | Some(_) => true 
    end
end

function is_balanced_help[a](tree: Tree[a]) -> Option[Int]
begin
    match tree with
    | Empty => Some(0)
    | Node(left, _, right) => 
        match (is_balanced_help(left), is_balanced_help(right)) with
        | (None, _) => None
        | (_, None) => None
        | (Some(left_height), Some(right_height)) =>
            let diff_height = left_height - right_height;
            if diff_height >= -1 && diff_height <= 1 then
                if left_height < right_height then 
                    Some(right_height + 1)
                else
                    Some(left_height + 1)
            else
                None
        end
    end
end

function is_sorted(tree: Tree[Int]) -> Bool
begin
    match tree with
    | Empty => true
    | Node(left, x, right) =>
        is_sorted_max(left, x) && is_sorted_min(right, x)
    end
end

function is_sorted_min(tree: Tree[Int], min: Int) -> Bool
begin
    match tree with
    | Empty => true
    | Node(left, x, right) =>
        x > min &&
        is_sorted_min_max(left, min, x) && is_sorted_min(right, x)
    end
end

function is_sorted_max(tree: Tree[Int], max: Int) -> Bool
begin
    match tree with
    | Empty => true
    | Node(left, x, right) =>
        x < max &&
        is_sorted_max(left, x) && is_sorted_min_max(right, x, max)
    end
end

function is_sorted_min_max(tree: Tree[Int], min: Int, max: Int) -> Bool
begin
    match tree with
    | Empty => true
    | Node(left, x, right) =>
        x > min && x < max &&
        is_sorted_min_max(left, min, x) && is_sorted_min_max(right, x, max)
    end
end

function example(tree: Tree[Int])
begin
    guard is_sorted(tree) = true;
    guard is_balanced(tree) = true;
end

query example(depth_step=5, depth_limit=30, answer_limit=20)