datatype Expr where
| Cst(Value)
| Var(Int)
end

datatype Value where
| VInt(Int)
| VBool(Bool)
end

datatype Type where
| TyInt
| TyBool
| TyArr(Type, Type)
end

function value_type(val: Value) -> Type
begin
    match val with
    | VInt(_) => TyInt
    | VBool(_) => TyBool
    end
end

datatype List[a] where
| Nil
| Cons(a, List[a])
end

function context_lookup(ctx: List[(Int, Type)], x: Int) -> Type
begin
    match ctx with
    | Cons((y, ty), tail) =>
        if x == y then ty else context_lookup(tail, x)
    | Nil => undefined
    end
end

function infer_expr(ctx: List[(Int, Type)], expr: Expr) -> Type
begin
    match expr with
    | Cst(val) => value_type(val)
    | Var(x) => context_lookup(ctx, x)
    end
end

datatype Stmt where
| Def(Int, Type)
| Set(Int, Expr)
| Ifte(Expr, Stmt, Stmt)
end

datatype Stmts where
| Seq(List[Stmt])
end

function infer_stmt(ctx: List[(Int, Type)], stmt: Stmt) -> List[(Int, Type)]
begin
    match stmt with
    | Def(x, ty) => Cons((x, ty), ctx)
    | Set(x, expr) =>
        let ty = context_lookup(ctx, x);
        guard ty = infer_expr(ctx, expr);
        ctx
    | Ifte(cond, th_br, el_br) =>
        let cond_ty = infer_expr(ctx, cond);
        guard cond_ty = TyBool;
        let _ = infer_stmt(ctx, th_br);
        let _ = infer_stmt(ctx, el_br);
        ctx
    end
end

function infer_stmts(ctx: List[(Int, Type)], stmts: Stmts) -> List[(Int, Type)]
begin
    match stmts with
    | Seq(Nil) => ctx
    | Seq(Cons(stmt, tail)) =>
        let ctx2 = infer_stmt(ctx, stmt);
        infer_stmts(ctx2, Seq(tail))
    end
end

function example(stmts: Stmts)
begin
    fresh ctx;
    guard infer_stmts(Nil, stmts) = ctx;
end

query example(depth_step=5, depth_limit=30, answer_limit=100)