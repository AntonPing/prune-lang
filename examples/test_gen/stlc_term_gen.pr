datatype Expr where
| Cst(Value)
| Var(Int)
| Abs(Int, Type, Expr)
| App(Expr, Expr)
end

datatype Value where
| VInt(Int)
| VBool(Bool)
end

datatype Type where
| TyInt
| TyBool
| TyArr(Type, Type)
end

function value_type(val: Value) -> Type
begin
    match val with
    | VInt(_) => TyInt
    | VBool(_) => TyBool
    end
end

datatype List[a] where
| Nil
| Cons(a, List[a])
end

function context_lookup(ctx: List[(Int, Type)], x: Int) -> Type
begin
    match ctx with
    | Cons((y, ty), tail) =>
        if x == y then ty else context_lookup(tail, x)
    | Nil => undefined
    end
end

function type_infer(ctx: List[(Int, Type)], expr: Expr) -> Type
begin
    match expr with
    | Cst(x) => value_type(x)
    | Var(x) => context_lookup(ctx, x)
    | Abs(x, ty, e) =>
        let ty2 = type_infer(Cons((x, ty), ctx), e);
        TyArr(ty, ty2)
    | App(e1, e2) =>
        let TyArr(lhs, rhs) = type_infer(ctx, e1);
        guard lhs = type_infer(ctx, e2);
        rhs
    end
end

function example(expr: Expr, ty: Type)
begin
    guard type_infer(Nil, expr) = ty;
end

query example(depth_step=5, depth_limit=30, answer_limit=100)